PORT=4000
MONGODB_URI=mongodb://localhost:27017/milart
NODE_ENV=development

# Optional — when both are set, image uploads go to Supabase Storage and
# returned URLs are public Supabase URLs that survive redeploys.
# Without these the server falls back to local-disk storage at UPLOAD_DIR.
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_BUCKET=images
